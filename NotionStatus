import os
import re
import requests
from github import Github
from notion_client import Client
from dotenv import load_dotenv

# 1. 환경 변수 로드
load_dotenv()

GH_TOKEN = os.getenv("GH_TOKEN")
NOTION_TOKEN = os.getenv("NOTION_TOKEN")
NOTION_DB_ID = os.getenv("NOTION_DB_ID")
REPO_NAME = os.getenv("REPO_NAME")

# 2. 상태 매핑 (노션 속성값과 정확히 일치해야 함)
STATUS_MAP = {
    "#idea": "아이디어",
    "#coding": "코딩중",
    "#review": "검토중",
    "#debug": "디버깅중",
    "#done": "완료"
}

# 노션 API 헤더 (requests용)
headers = {
    "Authorization": f"Bearer {NOTION_TOKEN}",
    "Content-Type": "application/json",
    "Notion-Version": "2022-06-28"
}

def get_page_id_by_task_id(task_id_number):
    """노션 고유 ID를 이용해 해당 데이터(Page)의 진짜 ID를 찾아오는 함수"""
    url = f"https://api.notion.com/v1/databases/{NOTION_DB_ID}/query"
    payload = {
        "filter": {
            "property": "ID",  # ⚠️ 노션의 고유 ID 속성 이름이 정확히 'ID'여야 합니다.
            "unique_id": {"equals": int(task_id_number)}
        }
    }
    response = requests.post(url, headers=headers, json=payload)
    if response.status_code == 200:
        results = response.json().get("results")
        if results:
            return results[0]["id"]
    else:
        print(f"❌ 데이터베이스 검색 실패: {response.text}")
    return None

def update_task_status(page_id, new_status):
    """찾아낸 Page ID를 바탕으로 상태를 변경하는 함수"""
    url = f"https://api.notion.com/v1/pages/{page_id}"
    payload = {
        "properties": {
            "작업 상태": { # ⚠️ 노션 속성명이 '작업 상태'가 아니라면 수정하세요!
                "status": {"name": new_status}
            }
        }
    }
    response = requests.patch(url, headers=headers, json=payload)
    if response.status_code == 200:
        print(f"✅ 상태 업데이트 성공: '{new_status}'(으)로 변경됨!")
    else:
        print(f"❌ 상태 업데이트 실패: {response.text}")
    return response.status_code == 200

def process_commit_message(commit_message):
    """커밋 메시지를 분석해서 태스크 번호와 상태를 찾는 함수"""
    if not commit_message: return
    
    print(f"🔍 커밋 메시지 분석 중: {commit_message}")
    
    # [MBC-번호] 추출
    task_match = re.search(r"MBC-(\d+)", commit_message.upper())
    if not task_match: 
        print("ℹ️ 커밋 메시지에서 'MBC-번호'를 찾지 못해 상태를 변경하지 않습니다.")
        return
        
    task_number = task_match.group(1)
    print(f"📌 발견된 태스크 번호: {task_number}")
    
    # 상태 태그 매칭
    msg_lower = commit_message.lower()
    new_status = next((status for tag, status in STATUS_MAP.items() if tag in msg_lower), None)

    if new_status:
        page_id = get_page_id_by_task_id(task_number)
        if page_id:
            update_task_status(page_id, new_status)
        else:
            print(f"❌ 노션에서 ID가 '{task_number}'인 페이지를 찾을 수 없습니다.")
    else:
        print("ℹ️ 커밋 메시지에서 상태 변경 태그(예: #done)를 찾지 못했습니다.")

def sync_to_notion():
    """깃허브 커밋을 가져와 노션에 기록하고, 상태도 업데이트하는 메인 함수"""
    try:
        g = Github(GH_TOKEN)
        notion = Client(auth=NOTION_TOKEN)
        repo = g.get_repo(REPO_NAME)

        # 3. 가장 최근 커밋 정보 추출
        commit = repo.get_commits()[0]
        msg = commit.commit.message
        author = commit.commit.author.name
        url = commit.html_url
        date = commit.commit.author.date.isoformat() 

        # 4. 노션 데이터베이스에 '커밋 기록' 새 행 추가
        notion.pages.create(
            parent={"database_id": NOTION_DB_ID},
            properties={
                "Name": {"title": [{"text": {"content": msg}}]},
                "Author": {"rich_text": [{"text": {"content": author}}]},
                "URL": {"url": url},
                "Date": {"date": {"start": date}} 
            }
        )
        print(f"🚀 성공! '{msg}' 커밋이 노션에 새 기록으로 추가되었습니다.")
        
        # 5. 추출한 커밋 메시지(msg)를 분석하여 기존 태스크의 '상태' 변경 시도
        process_commit_message(msg)
        
    except Exception as e:
        print(f"❌ 에러 발생: {e}")

# 파이썬 실행의 진짜 시작점
if __name__ == "__main__":
    sync_to_notion()
