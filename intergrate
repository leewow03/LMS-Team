import os
import re
import requests
from github import Github, Auth
from notion_client import Client

# 1. 환경 변수 설정
GH_TOKEN = os.environ.get("GH_TOKEN")
NOTION_TOKEN = os.environ.get("NOTION_TOKEN")
REPO_NAME = os.environ.get("REPO_NAME")

# DB ID 분리
NOTION_TASK_DB_ID = os.environ.get("NOTION_DB_ID")        # 상태 관리용 (태스크 보드)
NOTION_COMMIT_DB_ID = os.environ.get("NOTION_COMMIT_DB_ID") # 커밋 기록 전용

# 2. 상태 매핑
STATUS_MAP = {
    "#idea": "아이디어",
    "#coding": "코딩중",
    "#review": "검토중",
    "#debug": "디버깅중",
    "#done": "완료"
}

headers = {
    "Authorization": f"Bearer {NOTION_TOKEN}",
    "Content-Type": "application/json",
    "Notion-Version": "2022-06-28"
}

def get_page_id_by_task_id(task_id_number):
    """상태 관리용 DB에서 고유 ID로 페이지를 찾는 함수"""
    url = f"https://api.notion.com/v1/databases/{NOTION_TASK_DB_ID}/query"
    
    # ⚠️ 중요: 노션 DB의 고유 ID 컬럼 이름이 'ID'가 맞는지 꼭 확인하세요!
    payload = {
        "filter": {
            "property": "ID", 
            "unique_id": {
                "equals": int(task_id_number)
            }
        }
    }
    
    response = requests.post(url, headers=headers, json=payload)
    
    if response.status_code == 200:
        results = response.json().get("results")
        if results:
            return results[0]["id"]
        else:
            print(f"🧐 결과 없음: 태스크 DB에서 'SCH-{task_id_number}'를 찾지 못했습니다.")
    else:
        print(f"❌ API 오류: {response.status_code}, {response.text}")
    return None

def update_task_status(page_id, new_status):
    """태스크 DB의 '작업 상태'를 업데이트"""
    url = f"https://api.notion.com/v1/pages/{page_id}"
    payload = {
        "properties": {
            "작업 상태": { 
                "status": {"name": new_status}
            }
        }
    }
    response = requests.patch(url, headers=headers, json=payload)
    return response.status_code == 200

def process_commit_message(commit_message):
    """메시지 분석 및 상태 변경 실행"""
    if not commit_message: return
    
    task_match = re.search(r"SCH-(\d+)", commit_message.upper())
    if not task_match:
        print("ℹ️ 'SCH-번호' 패턴이 없어 상태 변경을 건너뜁니다.")
        return
        
    task_number = task_match.group(1)
    msg_lower = commit_message.lower()
    new_status = next((status for tag, status in STATUS_MAP.items() if tag in msg_lower), None)

    if new_status:
        page_id = get_page_id_by_task_id(task_number)
        if page_id:
            if update_task_status(page_id, new_status):
                print(f"✅ 태스크 보드의 SCH-{task_number} 상태가 '{new_status}'로 변경되었습니다!")
        else:
            print(f"❌ 태스크 DB에서 ID {task_number}를 찾을 수 없어 상태를 못 바꿨습니다.")

def sync_to_notion():
    """메인 실행 로직"""
    try:
        # 깃허브 인증 경고 해결
        auth = Auth.Token(GH_TOKEN)
        g = Github(auth=auth)
        notion = Client(auth=NOTION_TOKEN)
        repo = g.get_repo(REPO_NAME)

        commit = repo.get_commits()[0]
        msg = commit.commit.message
        author = commit.commit.author.name
        url = commit.html_url
        date = commit.commit.author.date.isoformat() 

        # 1단계: 커밋 기록 전용 DB에 저장
        notion.pages.create(
            parent={"database_id": NOTION_COMMIT_DB_ID},
            properties={
                "Name": {"title": [{"text": {"content": msg}}]},
                "Author": {"rich_text": [{"text": {"content": author}}]},
                "URL": {"url": url},
                "Date": {"date": {"start": date}} 
            }
        )
        print(f"🚀 성공! 커밋 로그 DB에 기록 완료: {msg}")
        
        # 2단계: 태스크 보드 DB 상태 변경 시도
        process_commit_message(msg)
        
    except Exception as e:
        print(f"❌ 에러 발생: {e}")

if __name__ == "__main__":
    sync_to_notion()
