import os
import re
from github import Github, Auth  
from notion_client import Client

# 1. 환경 변수 설정
GH_TOKEN = os.environ.get("GH_TOKEN")
NOTION_TOKEN = os.environ.get("NOTION_TOKEN")
NOTION_DB_ID = os.environ.get("NOTION_DB_ID")         # 커밋 기록용 DB
NOTION_STATUS_DB_ID = os.environ.get("NOTION_STATUS_DB_ID") # 상태 관리 DB
REPO_NAME = os.environ.get("REPO_NAME")

# 상태 매핑 설정 (키워드: 노션에 등록된 상태 이름)
STATUS_MAP = {
    "#idea": "아이디어",
    "#coding": "코딩중",
    "#review": "검토중",
    "#debug": "디버깅중",
    "#done": "완료"
}

def process_commit_message(msg):
    """
    커밋 메시지에서 ID와 키워드를 찾아 상태 DB를 업데이트합니다.
    """
    # 1. 키워드 확인
    found_status = None
    for keyword, status_name in STATUS_MAP.items():
        if keyword in msg:
            found_status = status_name
            break
            
    if not found_status:
        return

    # 2. 작업 ID(STA-XXX) 찾기
    match = re.search(r'STA-\d+', msg)
    if not match:
        return

    task_id = match.group()
    print(f"⚙️ '{task_id}' 항목을 '{found_status}' 상태로 업데이트 시도 중...")
    
    try:
        notion = Client(auth=NOTION_TOKEN)
        # ID로 페이지 검색
        query = notion.databases.query(
            database_id=NOTION_STATUS_DB_ID,
            filter={"property": "ID", "rich_text": {"equals": task_id}}
        )
        
        if query['results']:
            page_id = query['results'][0]['id']
            # 상태 속성 업데이트
            notion.pages.update(
                page_id=page_id,
                properties={"Status": {"status": {"name": found_status}}}
            )
            print(f"✅ 성공! {task_id}가 '{found_status}'(으)로 업데이트되었습니다.")
    except Exception as e:
        print(f"⚠️ 상태 DB 업데이트 중 에러 발생: {e}")

def sync_to_notion():
    try:
        auth = Auth.Token(GH_TOKEN)
        g = Github(auth=auth)
        notion = Client(auth=NOTION_TOKEN)
        repo = g.get_repo(REPO_NAME)

        commits = repo.get_commits()
        if commits.totalCount == 0:
            print("⚠️ 커밋 기록이 없습니다.")
            return

        # 최신 커밋 가져오기
        commit = commits[0]
        msg = commit.commit.message
        author = commit.commit.author.name
        url = commit.html_url
        date = commit.commit.author.date.isoformat() 

        # 1단계: 커밋 기록을 노션 DB에 추가
        notion.pages.create(
            parent={"database_id": NOTION_DB_ID},
            properties={
                "Name": {"title": [{"text": {"content": msg}}]},
                "Author": {"rich_text": [{"text": {"content": author}}]},
                "URL": {"url": url},
                "Date": {"date": {"start": date}} 
            }
        )
        print(f"🚀 성공! '{msg}' 커밋이 노션에 기록되었습니다.")
        
        # 2단계: 상태 업데이트 처리
        process_commit_message(msg)
        
    except Exception as e:
        print(f"❌ 에러 발생: {e}")

if __name__ == "__main__":
    sync_to_notion()
