import os
import re
import json
import requests
from github import Github, Auth

# 환경 변수 설정
GH_TOKEN = os.environ.get("GH_TOKEN")
NOTION_TOKEN = os.environ.get("NOTION_TOKEN")
NOTION_DB_ID = os.environ.get("NOTION_DB_ID")
NOTION_STATUS_DB_ID = os.environ.get("NOTION_STATUS_DB_ID")
REPO_NAME = os.environ.get("REPO_NAME")

STATUS_MAP = {
    "#idea": "아이디어",
    "#coding": "코딩중",
    "#review": "검토중",
    "#debug": "디버깅중",
    "#done": "완료"
}

HEADERS = {
    "Authorization": f"Bearer {NOTION_TOKEN}",
    "Content-Type": "application/json",
    "Notion-Version": "2022-06-28"
}

def update_task_status(msg):
    found_status = next((status for key, status in STATUS_MAP.items() if key in msg), None)
    match = re.search(r'STA-\d+', msg)
    
    if not found_status or not match:
        print("ℹ️ 업데이트 대상 없음")
        return

    task_id = match.group() # 예: "STA-5"
    clean_db_id = NOTION_STATUS_DB_ID.strip().replace("-", "")
    
    try:
        query_url = f"https://api.notion.com/v1/databases/{clean_db_id}/query"
        res = requests.post(query_url, headers=HEADERS, json={})
        data = res.json()
        results = data.get('results', [])

        target_page_id = None
        for page in results:
            props = page.get('properties', {})
            
            # [수정] 고유 ID(unique_id) 유형에서 값 추출
            # 노션 API에서 고유 ID는 'unique_id' 키 안에 'prefix'와 'number'로 나뉩니다.
            uid_prop = props.get('ID', {}).get('unique_id', {})
            if uid_prop:
                prefix = uid_prop.get('prefix') or ""
                number = uid_prop.get('number')
                # 접두어와 숫자를 합쳐서 "STA-5" 형태를 만듭니다.
                actual_full_id = f"{prefix}-{number}" if prefix else str(number)
                
                if actual_full_id == task_id:
                    target_page_id = page['id']
                    break
        
        if target_page_id:
            update_url = f"https://api.notion.com/v1/pages/{target_page_id}"
            res_up = requests.patch(update_url, headers=HEADERS, json={
                "properties": {"상태": {"select": {"name": found_status}}}
            })
            if res_up.status_code == 200:
                print(f"✅ [상태 DB] {task_id} -> {found_status} 완료!")
            else:
                print(f"❌ 업데이트 실패: {res_up.text}")
        else:
            print(f"⚠️ {task_id}와 일치하는 고유 ID를 찾지 못했습니다.")
            
    except Exception as e:
        print(f"⚠️ 에러 발생: {e}")
            
    except Exception as e:
        print(f"⚠️ 에러 발생: {e}")

def commit_to_notion(msg, author, url, date):
    try:
        clean_log_db_id = NOTION_DB_ID.strip().replace("-", "")
        create_url = "https://api.notion.com/v1/pages"
        payload = {
            "parent": {"database_id": clean_log_db_id},
            "properties": {
                "Name": {"title": [{"text": {"content": msg}}]},
                "Author": {"rich_text": [{"text": {"content": author}}]},
                "URL": {"url": url},
                "Date": {"date": {"start": date}} 
            }
        }
        res = requests.post(create_url, headers=HEADERS, json=payload)
        if res.status_code == 200:
            print(f"🚀 [로그 DB] 커밋 기록 완료: {msg}")
        else:
            print(f"❌ 로그 DB 기록 실패: {res.text}")
    except Exception as e:
        print(f"⚠️ 로그 DB 오류: {e}")

def sync_to_notion():
    try:
        auth = Auth.Token(GH_TOKEN)
        g = Github(auth=auth)
        repo = g.get_repo(REPO_NAME)
        commits = repo.get_commits()

        if commits.totalCount == 0:
            return

        latest_commit = commits[0]
        msg = latest_commit.commit.message
        author = latest_commit.commit.author.name
        url = latest_commit.html_url
        date = latest_commit.commit.author.date.isoformat()
        
        commit_to_notion(msg, author, url, date)
        update_task_status(msg)
        
    except Exception as e:
        print(f"❌ 전체 에러: {e}")

if __name__ == "__main__":
    sync_to_notion()
