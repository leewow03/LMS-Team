import os
import re
from github import Github, Auth
from notion_client import Client

# 1. 환경 변수 설정
GH_TOKEN = os.environ.get("GH_TOKEN")
NOTION_TOKEN = os.environ.get("NOTION_TOKEN")
NOTION_DB_ID = os.environ.get("NOTION_DB_ID")
NOTION_STATUS_DB_ID = os.environ.get("NOTION_STATUS_DB_ID")
REPO_NAME = os.environ.get("REPO_NAME")

STATUS_MAP = {
    "#idea": "아이디어",
    "#coding": "코딩중",
    "#review": "검토중",
    "#debug": "디버깅중",
    "#done": "완료"
}

def update_task_status(notion, msg):
    found_status = next((status for key, status in STATUS_MAP.items() if key in msg), None)
    match = re.search(r'STA-\d+', msg)
    
    if not found_status or not match:
        return

    task_id = match.group()
    
    # DB ID에서 불필요한 공백과 하이픈을 제거하여 순수한 32자리 ID만 추출
    # Secret에 URL이 들어있어도 ID만 뽑아내도록 설계
    raw_id = NOTION_STATUS_DB_ID.strip()
    clean_db_id = raw_id.split('/')[-1].split('?')[0].replace('-', '')
    
    print(f"⚙️ [상태 DB] '{task_id}' -> '{found_status}' 업데이트 시도...")
    
    try:
        # 1. 항목 조회 (가장 안전한 호출 방식)
        query_params = {
            "database_id": clean_db_id,
            "filter": {
                "property": "ID",
                "rich_text": {"equals": task_id}
            }
        }
        
        # notion.databases.query가 에러 났던 것을 대비해 속성에 직접 접근
        response = notion.databases.query(**query_params)
        
        results = response.get("results", [])
        
        if results:
            page_id = results[0]['id']
            # 2. 상태 업데이트
            notion.pages.update(
                page_id=page_id,
                properties={
                    "상태": {"select": {"name": found_status}}
                }
            )
            print(f"✅ [상태 DB] 업데이트 완료!")
        else:
            print(f"⚠️ '{task_id}' 항목을 찾을 수 없습니다. (DB에 해당 ID가 있는지 확인하세요)")
            
    except Exception as e:
        print(f"⚠️ 상태 DB 업데이트 오류 상세: {e}")

print(f"DEBUG: clean_db_id is {clean_db_id}")

def commit_to_notion(notion, msg, author, url, date): # notion 객체를 인자로 받음
    try:
        notion.pages.create(
            parent={"database_id": NOTION_DB_ID},
            properties={
                "Name": {"title": [{"text": {"content": msg}}]},
                "Author": {"rich_text": [{"text": {"content": author}}]},
                "URL": {"url": url},
                "Date": {"date": {"start": date}} 
            }
        )
        print(f"🚀 [로그 DB] 커밋 기록 완료: '{msg}'")
    except Exception as e:
        print(f"⚠️ 로그 DB 기록 오류: {e}")

def sync_to_notion():
    try:
        # Notion 클라이언트 초기화
        notion = Client(auth=NOTION_TOKEN)
        
        # GitHub 클라이언트 초기화
        auth = Auth.Token(GH_TOKEN)
        g = Github(auth=auth)
        repo = g.get_repo(REPO_NAME)
        commits = repo.get_commits()

        if commits.totalCount == 0:
            print("⚠️ 커밋 기록이 없습니다.")
            return

        latest_commit = commits[0]
        msg = latest_commit.commit.message
        author = latest_commit.commit.author.name
        url = latest_commit.html_url
        date = latest_commit.commit.author.date.isoformat()
        
        # 1. 커밋 로그 기록 (notion 객체 전달)
        commit_to_notion(notion, msg, author, url, date)
        
        # 2. 상태 업데이트 (notion 객체 전달)
        update_task_status(notion, msg)
        
    except Exception as e:
        print(f"❌ 전체 프로세스 에러: {e}")

if __name__ == "__main__":
    sync_to_notion()
